    "# Chạy thực nghiệm đo thời gian\n",
    "n_values = [50, 100, 200, 500, 1000] \n",
    "\n",
    "my_solvers = {\n",
    "        'Gauss': lambda A, b: sv.gaussian_elimination(A, b)[1], \n",
    "        'LU': sv.solve_lu,\n",
