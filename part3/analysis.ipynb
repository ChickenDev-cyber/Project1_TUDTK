    "}\n",
    "\n",
    "print(\"Đang chạy benchmark đo thời gian...\")\n",
    "perf_results = bm.benchmark_performance(my_solvers, n_values=n_values)\n",
    "\n",
    "# Hiển thị kết quả ra bảng\n",
    "df_time = pd.DataFrame({\n",
